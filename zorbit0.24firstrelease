-- Feature Setup Functions
function setupPremiumFeatures()
    local aimFrame = tabFrames["Aimbot"].Frame
    createToggle(aimFrame, "Enabled", function(v) Settings.Aimbot.Enabled = v end)
    createSlider(aimFrame, "Sensitivity (Smoothing)", 1, 20, 5, function(v) Settings.Aimbot.Smoothing = v end)
    createSlider(aimFrame, "FOV Radius", 10, 500, 100, function(v) Settings.Aimbot.FOV = v end)
    
    local fovCircle = create("Frame", {Size = UDim2.new(0, 200, 0, 200), BackgroundTransparency = 1, Parent = sg})
    create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = fovCircle})
    local stroke = create("UIStroke", {Color = GOLD_COLOR, Thickness = 1, Transparency = 0.5, Parent = fovCircle})

    local function getClosestPlayer()
        local target, dist = nil, Settings.Aimbot.FOV
        local center = Camera.ViewportSize / 2
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild(Settings.Aimbot.TargetPart) then
                if Settings.Visuals.TeamCheck and p.Team == player.Team then continue end
                local pos, onScreen = Camera:WorldToViewportPoint(p.Character[Settings.Aimbot.TargetPart].Position)
                -- Added Z-check to ensure they aren't behind the camera
                if onScreen and pos.Z > 0 then
                    local mag = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if mag < dist then
                        dist = mag
                        target = p
                    end
                end
            end
        end
        return target
    end

    RunService.RenderStepped:Connect(function()
        local center = Camera.ViewportSize / 2
        fovCircle.Position = UDim2.new(0, center.X - Settings.Aimbot.FOV, 0, center.Y - Settings.Aimbot.FOV)
        fovCircle.Size = UDim2.new(0, Settings.Aimbot.FOV * 2, 0, Settings.Aimbot.FOV * 2)
        fovCircle.Visible = Settings.Aimbot.Enabled
        
        if Settings.Aimbot.Enabled then
            local target = getClosestPlayer()
            if target and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                local targetPart = target.Character[Settings.Aimbot.TargetPart]
                local targetPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local move = (Vector2.new(targetPos.X, targetPos.Y) - center) / math.max(Settings.Aimbot.Smoothing, 1)
                    if mousemoverel then
                        mousemoverel(move.X, move.Y)
                    else
                        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
                    end
                end
            end
        end
    end)
end

function setupStandardFeatures()
    createToggle(tabFrames["Triggerbot"].Frame, "Enabled", function(v) Settings.Triggerbot.Enabled = v end)
    createSlider(tabFrames["Triggerbot"].Frame, "Delay (ms)", 0, 500, 50, function(v) Settings.Triggerbot.Delay = v/1000 end)

    task.spawn(function()
        while task.wait() do
            if Settings.Triggerbot.Enabled then
                local rayParams = RaycastParams.new()
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                -- Improved filter: ignore character AND any local viewmodels in camera
                local filter = {player.Character, Camera}
                rayParams.FilterDescendantsInstances = filter
                
                local rayOrigin = Camera.CFrame.Position
                local rayDirection = Camera.CFrame.LookVector * Settings.Triggerbot.Range
                local result = workspace:Raycast(rayOrigin, rayDirection, rayParams)
                
                if result and result.Instance then
                    local hit = result.Instance
                    local character = hit:FindFirstAncestorOfClass("Model")
                    if character and character:FindFirstChild("Humanoid") then
                        local p = Players:GetPlayerFromCharacter(character)
                        if p and (not Settings.Visuals.TeamCheck or p.Team ~= player.Team) then
                            task.wait(Settings.Triggerbot.Delay)
                            if mouse1click then mouse1click() 
                            elseif keypress then mouse1press() task.wait(0.01) mouse1release() end
                        end
                    end
                end
            end
        end
    end)

    createToggle(tabFrames["Visuals"].Frame, "Box ESP", function(v) Settings.Visuals.BoxEsp = v end)
    createToggle(tabFrames["Visuals"].Frame, "Tracers (ESP Lines)", function(v) Settings.Visuals.Tracers = v end)
    createToggle(tabFrames["Visuals"].Frame, "Team Check", function(v) Settings.Visuals.TeamCheck = v end)

    local espObjects = {}
    RunService.RenderStepped:Connect(function()
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player then
                local char = p.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local isTeammate = Settings.Visuals.TeamCheck and p.Team == player.Team
                    
                    if Settings.Visuals.BoxEsp and not isTeammate then
                        local h = espObjects[p] and espObjects[p].Highlight or create("Highlight", {Parent = char, Name = "ZorbitESP"})
                        h.Adornee = char
                        h.FillColor = p.TeamColor.Color
                        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        h.Enabled = true
                        if not espObjects[p] then espObjects[p] = {Highlight = h} else espObjects[p].Highlight = h end
                    elseif espObjects[p] and espObjects[p].Highlight then
                        espObjects[p].Highlight.Enabled = false
                    end

                    if Settings.Visuals.Tracers and not isTeammate then
                        local pos, onScreen = Camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
                        if onScreen and pos.Z > 0 then
                            local tracer = espObjects[p] and espObjects[p].Tracer or create("Frame", {Parent = sg, BackgroundColor3 = p.TeamColor.Color, BorderSizePixel = 0, AnchorPoint = Vector2.new(0.5, 0)})
                            local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                            local targetPos = Vector2.new(pos.X, pos.Y)
                            local dist = (targetPos - screenCenter).Magnitude
                            
                            tracer.Size = UDim2.new(0, 2, 0, dist)
                            tracer.Position = UDim2.new(0, screenCenter.X, 0, screenCenter.Y)
                            tracer.Rotation = math.deg(math.atan2(targetPos.Y - screenCenter.Y, targetPos.X - screenCenter.X)) - 90
                            tracer.Visible = true
                            if not espObjects[p] then espObjects[p] = {Tracer = tracer} else espObjects[p].Tracer = tracer end
                        elseif espObjects[p] and espObjects[p].Tracer then
                            espObjects[p].Tracer.Visible = false
                        end
                    elseif espObjects[p] and espObjects[p].Tracer then
                        espObjects[p].Tracer.Visible = false
                    end
                end
            end
        end
    end)

    createToggle(tabFrames["Misc"].Frame, "NoClip", function(v) Settings.Misc.NoClip = v end)
    createToggle(tabFrames["Misc"].Frame, "Infinite Jump", function(v) Settings.Misc.InfiniteJump = v end)
    createSlider(tabFrames["Misc"].Frame, "WalkSpeed", 16, 200, 16, function(v) Settings.Misc.WalkSpeed = v end)

    local function addSettingBtn(text, callback)
