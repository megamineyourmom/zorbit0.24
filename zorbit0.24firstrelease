-- Utility: Quick Instance Creator
local function create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do inst[k] = v end
    return inst
end

-- Background Rain Animation Logic
local function initRain(parentFrame)
    local rainContainer = create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 0,
        Parent = parentFrame
    })

    task.spawn(function()
        while task.wait(0.04) do
            if not parentFrame or not parentFrame.Parent then break end
            if not parentFrame.Visible then continue end
            
            local bit = create("Frame", {
                Size = UDim2.new(0, 1, 0, math.random(10, 20)),
                Position = UDim2.new(math.random(), 0, -0.1, 0),
                BackgroundColor3 = Settings.UI.RainColor,
                BackgroundTransparency = RAIN_TRANSPARENCY,
                BorderSizePixel = 0,
                ZIndex = 1,
                Parent = rainContainer
            })
            
            local fallSpeed = math.random(400, 600)
            local connection
            connection = RunService.RenderStepped:Connect(function(dt)
                if not bit or not bit.Parent then 
                    connection:Disconnect() 
                    return 
                end
                bit.BackgroundColor3 = Settings.UI.RainColor
                bit.Position = bit.Position + UDim2.new(0, 0, 0, fallSpeed * dt)
                if bit.Position.Y.Offset > parentFrame.AbsoluteSize.Y + 50 then
                    connection:Disconnect()
                    bit:Destroy()
                end
            end)
        end
    end)
end

-- UI Component Helpers
local function createToggle(parent, text, callback)
    local bg = create("Frame", {
        Size = UDim2.new(1, -20, 0, 30),
        BackgroundColor3 = Color3.fromRGB(25, 25, 25),
        BorderSizePixel = 0,
        Parent = parent
    })
    create("TextLabel", {
        Size = UDim2.new(0.7, 0, 1, 0),
        Position = UDim2.new(0.05, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Color3.fromRGB(200, 200, 200),
        Font = THIN_FONT,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = bg
    })
    local btn = create("TextButton", {
        Size = UDim2.new(0, 50, 0, 20),
        Position = UDim2.new(0.95, -50, 0.5, -10),
        BackgroundColor3 = Color3.fromRGB(40, 40, 40),
        Text = "OFF",
        TextColor3 = Color3.fromRGB(255, 100, 100),
        Font = THIN_FONT,
        TextSize = 14,
        BorderSizePixel = 0,
        Parent = bg
    })
    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = state and "ON" or "OFF"
        btn.TextColor3 = state and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        callback(state)
    end)
    return bg
end

local function createSlider(parent, text, min, max, default, callback)
    local bg = create("Frame", {
        Size = UDim2.new(1, -20, 0, 45),
        BackgroundTransparency = 1,
        Parent = parent
    })
    local label = create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 20),
        BackgroundTransparency = 1,
        Text = text .. ": " .. default,
        TextColor3 = Color3.fromRGB(180, 180, 180),
        Font = THIN_FONT,
        TextSize = 14,
        Parent = bg
    })
    local sliderBg = create("Frame", {
        Size = UDim2.new(1, 0, 0, 10),
        Position = UDim2.new(0, 0, 0, 25),
        BackgroundColor3 = Color3.fromRGB(30, 30, 30),
        BorderSizePixel = 0,
        Parent = bg
    })
    local fill = create("Frame", {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Settings.UI.IsPremium and GOLD_COLOR or ACCENT_COLOR,
        BorderSizePixel = 0,
        Parent = sliderBg
    })
    
    local function update(input)
        local pos = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + (max - min) * pos)
        fill.Size = UDim2.new(pos, 0, 1, 0)
        label.Text = text .. ": " .. val
        callback(val)
    end

    local dragging = false
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(input) end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

