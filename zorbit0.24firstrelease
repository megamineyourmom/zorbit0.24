        btn.MouseButton1Click:Connect(callback)
    end

    local function setTheme(theme)
        Settings.UI.Theme = theme
        if theme == "Gold" then
            task.spawn(function()
                while Settings.UI.Theme == "Gold" do
                    TweenService:Create(main, TweenInfo.new(2), {BackgroundColor3 = Color3.fromRGB(150, 120, 0)}):Play()
                    task.wait(2)
                    TweenService:Create(main, TweenInfo.new(2), {BackgroundColor3 = Color3.fromRGB(80, 60, 0)}):Play()
                    task.wait(2)
                end
            end)
        elseif theme == "Purple" then
            task.spawn(function()
                while Settings.UI.Theme == "Purple" do
                    TweenService:Create(main, TweenInfo.new(2), {BackgroundColor3 = Color3.fromRGB(40, 0, 80)}):Play()
