-- Captcha Setup
local function generateCaptcha(len)
    local chars = "ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz1234567890"
    local str = ""
    for i = 1, len do local r = math.random(1, #chars) str = str .. string.sub(chars, r, r) end
    return str
end

